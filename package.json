{
  "name": "obsidian-tasks-kanban",
  "version": "0.8.2",
  "description": "Kanban board view for Obsidian Tasks",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian --watch",
    "build": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian --minify",
    "build:dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian",
    "dev:reload": "obsidian plugin:reload id=tasks-kanban",
    "dev:full": "npm run build:dev && npm run dev:reload",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "tasks",
    "kanban"
  ],
  "nano-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "author": "Julien Tanay",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "nano-staged": "^1.0.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "obsidian": "^1.13.1"
  }
}
