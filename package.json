{
  "name": "obsidian-tasks-kanban",
  "version": "0.1.0",
  "description": "Kanban board view for Obsidian Tasks",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian --watch",
    "build": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian --minify",
    "build:dev": "esbuild src/main.ts --bundle --outfile=main.js --format=cjs --platform=browser --target=es2020 --external:obsidian",
    "dev:reload": "obsidian plugin:reload id=obsidian-tasks-kanban",
    "dev:full": "npm run build:dev && npm run dev:reload",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "keywords": [
    "obsidian",
    "plugin",
    "tasks",
    "kanban"
  ],
  "author": "Julien Tanay",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/parser": "^8.61.0",
    "esbuild": "^0.19.11",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
